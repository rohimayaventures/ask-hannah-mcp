# Required API key (create in Anthropic Console): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Local server port (Railway injects PORT automatically in production)
PORT=3000

# Your deployed public base URL (Railway service URL): https://railway.com/project
BASE_URL=https://your-railway-url.railway.app

# Freshness metadata shown in MCP outputs
PROFILE_DATA_LAST_UPDATED=2026-04-09
MCP_CONTENT_SET_LAST_UPDATED=2026-04-09

# Optional service/build metadata
APP_VERSION=1.0.0
BUILD_DATE=2026-04-09
GIT_SHA=local

# Contact options (Calendly setup: https://calendly.com/app/scheduling-links)
CONTACT_EMAIL=your.email@example.com
CALENDLY_URL=https://calendly.com/your-handle/20min-intro
ZOOM_BOOKING_URL=
LINKEDIN_URL=https://www.linkedin.com/in/your-profile
