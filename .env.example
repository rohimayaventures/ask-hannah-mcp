# Required API key (create in Anthropic Console): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resume/cover-letter generation (optional overrides)
# ANTHROPIC_MODEL applies to both tools when the per-tool vars below are unset.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_MODEL_RESUME=
# ANTHROPIC_MODEL_COVER_LETTER=
# ANTHROPIC_RETRY_MAX_ATTEMPTS=3
# ANTHROPIC_RETRY_BASE_MS=1000

# Local server port (Railway injects PORT automatically in production)
PORT=3000

# Trust first proxy hop (recommended on Railway so rate limits use X-Forwarded-For). Set to 0 to disable.
# TRUST_PROXY=1

# Optional: limit POST /mcp requests per client IP (sliding window). Off unless enabled.
# MCP_RATE_LIMIT_ENABLED=0
# MCP_RATE_LIMIT_MAX=120
# MCP_RATE_LIMIT_WINDOW_MS=60000

# Your deployed public base URL (Railway service URL): https://railway.com/project
BASE_URL=https://your-railway-url.railway.app

# Freshness metadata shown in MCP outputs
PROFILE_DATA_LAST_UPDATED=2026-04-09
MCP_CONTENT_SET_LAST_UPDATED=2026-04-09

# Optional service/build metadata
APP_VERSION=1.0.0
BUILD_DATE=2026-04-09
GIT_SHA=local

# Contact options (Calendly setup: https://calendly.com/app/scheduling-links)
CONTACT_EMAIL=your.email@example.com
CALENDLY_URL=https://calendly.com/your-handle/20min-intro
ZOOM_BOOKING_URL=
LINKEDIN_URL=https://www.linkedin.com/in/your-profile
PREFERRED_CONTACT_METHOD=calendly
CONTACT_RESPONSE_TIME_HOURS=24
CONTACT_UTM_SOURCE=ask-hannah-mcp
CALENDLY_UTM_SOURCE=ask-hannah-mcp
CONTACT_TIMEZONE=America/Denver
BOOKING_CTA_LABEL=Book a discovery call
CALENDLY_EVENT_TYPE=
